// Cloudflare Workers static-assets deploy (Launch Start).
// The site is 100% prerendered — this config serves ./dist as static assets
// with no Worker script, no bindings, no secrets.
{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "launch-start",
  "compatibility_date": "2026-07-01",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  }
}
