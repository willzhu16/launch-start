# Copy to .env and fill in. All values are optional; unset ones hide the
# feature they drive.

# Contact address for the footer, About page, and Person JSON-LD.
PUBLIC_CONTACT_EMAIL=

# Overrides the canonical origin at deploy (defaults to https://willzhu.dev).
SITE_ORIGIN=

# Reserved for the planned YouTube snapshot sync.
PUBLIC_YOUTUBE_CHANNEL_ID=
