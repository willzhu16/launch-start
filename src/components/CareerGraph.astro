---
// The /about career git-graph: a static inline SVG.
// Positions are computed from src/data/career.ts — editing history never
// touches geometry. Experiences slot in by year (then file order), the years
// become tick marks on the timeline, and each side project branches off (and
// optionally merges back into) the node wired by its id. Horizontal scroll on
// small screens.
import { career } from '../data/career';
import { type Connector, layoutCareer } from '../lib/career-graph';
import { placeLabel } from '../lib/svg-label';

const W = 800;
const H = 230;
const MAIN_Y = 160;
const SIDE_Y = 82;
const YEAR_LABEL_Y = 16;
const GRID_TOP = 26;

const { mains, sides, years, connectors } = layoutCareer(career, {
  x0: 70,
  x1: 730,
  mainY: MAIN_Y,
  sideY: SIDE_Y,
});

// Cubic curve between two points with horizontal handles: a rise when a branch
// leaves the trunk, a fall when it merges back, a straight run when both
// endpoints share a lane. The reach shrinks for short spans so it never overshoots.
const connectorPath = (connector: Connector): string => {
  const { from, to } = connector;
  const reach = Math.min(45, Math.max(14, Math.abs(to.x - from.x) / 2));
  return `M ${from.x} ${from.y} C ${from.x + reach} ${from.y}, ${to.x - reach} ${to.y}, ${to.x} ${to.y}`;
};

const description = [
  'Career timeline as a commit graph.',
  `Career: ${mains.map((node) => `${node.year} ${node.label}`).join(', ')}.`,
  sides.length > 0
    ? `Side projects: ${sides.map((node) => `${node.year} ${node.label}`).join(', ')}, each branching off the role it grew from.`
    : '',
]
  .join(' ')
  .trim();
---

{
  career.length > 0 && (
    <figure class="graph">
      <div class="scroll">
        <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label={description} width={W} height={H}>
          {years.map((tick) => (
            <>
              <line x1={tick.x} y1={GRID_TOP} x2={tick.x} y2={MAIN_Y} class="year-grid" />
              <text x={tick.x + 6} y={YEAR_LABEL_Y} text-anchor="start" class="year-label">
                {tick.year}
              </text>
            </>
          ))}
          <line x1="40" y1={MAIN_Y} x2={W - 20} y2={MAIN_Y} class="lane-main" />
          {connectors.map((connector) => (
            <path d={connectorPath(connector)} class="lane-side" />
          ))}
          {mains.map((node) => {
            const p = placeLabel(node.x, node.label, W);
            return (
              <>
                <circle cx={node.x} cy={node.y} r="7" class="dot-main" />
                <text x={p.x} y={node.labelY} text-anchor={p.anchor} class="label">
                  {node.label}
                </text>
              </>
            );
          })}
          {sides.map((node) => {
            const p = placeLabel(node.x, node.label, W);
            return (
              <>
                <circle cx={node.x} cy={node.y} r="7" class="dot-side" />
                <text x={p.x} y={node.labelY} text-anchor={p.anchor} class="label label-side">
                  {node.label}
                </text>
              </>
            );
          })}
        </svg>
      </div>
      <figcaption class="mono">
        Dark line = career · pink branches = side projects, each peeling off the
        role it grew from and folding back in as skills
      </figcaption>
    </figure>
  )
}

<style>
  .graph {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--r-m);
    padding: var(--s-4);
    box-shadow: var(--shadow-s);
  }
  .scroll {
    overflow-x: auto;
  }
  svg {
    min-width: 640px;
    width: 100%;
    height: auto;
  }
  .lane-main {
    stroke: var(--muted);
    stroke-width: 2.5;
  }
  .lane-side {
    stroke: var(--pink);
    stroke-width: 2.5;
    fill: none;
  }
  .dot-main {
    fill: var(--muted);
  }
  .dot-side {
    fill: var(--pink);
  }
  .label {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    fill: var(--muted);
  }
  .label-side {
    fill: var(--rose-ink);
  }
  .year-grid {
    stroke: var(--line);
    stroke-width: 1;
  }
  .year-label {
    font-family: var(--font-mono);
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    fill: var(--ink);
  }
  figcaption {
    margin-top: var(--s-3);
    color: var(--muted);
    font-size: 0.6rem;
  }
</style>
