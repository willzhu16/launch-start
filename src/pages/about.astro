---
// /about — the complete portfolio on one page. This is
// the resume-link target; it must answer everything standalone.
import { Image } from 'astro:assets';
import avatarSrc from '../assets/avatar.webp';
import CareerGraph from '../components/CareerGraph.astro';
import NavLite from '../components/NavLite.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SectionLabel from '../components/SectionLabel.astro';
import { externalWork } from '../data/external-work';
import { site } from '../data/site';
import Base from '../layouts/Base.astro';
import { publishedProjects } from '../lib/content';
import { personLd, profilePageLd } from '../lib/seo';

const projects = await publishedProjects();
const ordered = [
  ...projects.filter((p) => p.data.featured),
  ...projects.filter((p) => !p.data.featured),
];

// Presence detection through the Vite module graph — resolved at compile time,
// independent of the build's working directory. The avatar is a static import
// above (a missing file fails the build loudly); the resume stays in public/
// for a stable /resume.pdf URL, so its presence is checked via glob keys.
const hasResume = Object.keys(import.meta.glob('/public/resume.pdf')).length > 0;

const profileLd = profilePageLd();
---

<Base
  page="About"
  description={`${site.author} — software engineer. Timed public sprints, documented weekly.`}
  jsonLd={[personLd(), profileLd]}
>
  <NavLite current="about" />
  <main id="main">
    <header class="head gridbg">
      <div class="head-inner">
        <Image
          class="avatar"
          src={avatarSrc}
          alt={site.author}
          width={216}
          height={216}
          densities={[1, 2]}
        />
        <div>
          <h1>{site.author}</h1>
          <p class="role">
            Software engineer building full-stack systems, developer tools, and public side-project sprints. Launch Start is where I turn ideas into real shipped projects, work against deadlines, and write honestly about what shipped, what broke, and what I learned along the way.
          </p>
          <div class="actions">
            {hasResume && <a class="btn btn-pink" href="/resume.pdf">Resume (PDF)</a>}
            {site.socials.github && <a class="btn" href={site.socials.github}>GitHub ↗</a>}
            {site.socials.linkedin && <a class="btn" href={site.socials.linkedin}>LinkedIn ↗</a>}
            <a class="btn" href={`mailto:${site.email}`}>Email</a>
          </div>
        </div>
      </div>
    </header>

    <div class="page">
      <section aria-label="career timeline">
        <SectionLabel label="The journey, as a commit graph" />
        <CareerGraph />
      </section>

      {
        (ordered.length > 0 || externalWork.length > 0) && (
          <section aria-label="projects">
            <SectionLabel label="Projects" />
            <div class="grid">
              {ordered.map((project) => (
                <ProjectCard project={project} />
              ))}
              {externalWork.map((work) => (
                <a class="external" href={work.repoUrl}>
                  <span class="external-title">{work.title}</span>
                  <p>{work.blurb}</p>
                  <span class="mono badge">GitHub ↗</span>
                </a>
              ))}
            </div>
          </section>
        )
      }

      <section class="about-cols" aria-label="how I work and skills">
        <div class="col">
          <h2 class="col-label mono">Current focus</h2>
          <div class="prose">
            <p>
              Right now, I’m focused on becoming a stronger engineer by shipping small, complete projects end to end: backend services, frontend interfaces, deployment workflows, security checks, documentation, and the messy parts that come after “it works on my machine.”
            </p>
            <p>
              I’m especially interested in developer tools, secure development, cloud infrastructure, AI-assisted engineering workflows, CI/CD pipelines, and turning side projects into products people can actually use.
            </p>
          </div>
        </div>
        <div class="col">
          <h2 class="col-label mono">Skills</h2>
          <div class="prose">
            <p>
              <strong>Languages</strong>: Java, Python, TypeScript/JavaScript, SQL, C, C++
              <br>
              <strong>Backend & Cloud</strong>: Flask, REST APIs, GraphQL, AWS, Docker, Kubernetes, GitLab CI/CD, HashiCorp Vault
              <br>
              <strong>Frontend & Tools</strong>: React, React Native, Postman, Bruno, Grafana, Git, code reviews
              <br>
              <strong>Machine Learning & AI</strong>: scikit-learn, PyTorch, Optuna, deep learning, LLMs, F2/F3-score, ROC-AUC, time-aware cross-validation, SMOTE
              <br>
              <strong>Quality & Ops</strong>: automated testing, regression testing, release validation, production debugging, technical documentation
            </p>
          </div>
        </div>
      </section>
    </div>
  </main>
</Base>

<style>
  .head {
    border-bottom: 1px solid var(--line);
    padding: var(--s-12) 0;
  }
  .head-inner {
    max-width: var(--page-max);
    margin-inline: auto;
    padding-inline: var(--s-4);
    display: flex;
    gap: var(--s-8);
    align-items: center;
    flex-wrap: wrap;
  }
  .avatar {
    width: 216px;
    height: 216px;
    border-radius: 50%;
    border: 3px solid var(--pink);
    background: var(--card);
    object-fit: cover;
    flex-shrink: 0;
  }
  h1 {
    font-size: var(--step-4);
  }
  .role {
    font-family: var(--font-body);
    max-width: var(--measure);
    margin-block: var(--s-3) var(--s-4);
  }
  .actions {
    display: flex;
    gap: var(--s-3);
    flex-wrap: wrap;
  }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: var(--s-6);
  }
  .external {
    display: grid;
    gap: var(--s-2);
    align-content: start;
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--r-m);
    box-shadow: var(--shadow-s);
    padding: var(--s-4);
    color: var(--ink);
    text-decoration: none;
  }
  .external-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step-1);
  }
  .external p {
    font-family: var(--font-body);
    font-size: 0.95rem;
  }
  .badge {
    color: var(--pink-deep);
  }
  .about-cols {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--s-8);
    margin-top: var(--s-8);
  }
  @media (min-width: 860px) {
    .about-cols {
      grid-template-columns: 1fr 1fr;
      gap: var(--s-12);
    }
  }
  .col-label {
    color: var(--rose-ink);
    padding-bottom: var(--s-2);
    border-bottom: 1px solid var(--line);
    margin-bottom: var(--s-4);
  }
  /* prose fills its column here rather than capping at a single reading measure,
     because two side-by-side columns already keep each line short enough */
  .about-cols .prose {
    max-width: none;
  }
</style>