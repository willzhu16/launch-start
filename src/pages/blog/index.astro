---
// /blog/ — the default view: writing grouped by project. Each project is a
// collapsible section listing its weekly logs (date right-aligned) with essays
// in a nested collapsible; non-project posts live under "General". Native
// <details>, no client JS. The chronological view lives at /blog/by-date/.
import BlogViewToggle from '../../components/BlogViewToggle.astro';
import NavLite from '../../components/NavLite.astro';
import PathCrumb from '../../components/PathCrumb.astro';
import ProjectMark from '../../components/ProjectMark.astro';
import SubscribeNote from '../../components/SubscribeNote.astro';
import TreeRow from '../../components/TreeRow.astro';
import Base from '../../layouts/Base.astro';
import { logPath, publishedLogs, publishedPosts, publishedProjects } from '../../lib/content';
import { blogLd } from '../../lib/seo';

const projects = await publishedProjects();
const allLogs = await publishedLogs();
const allPosts = await publishedPosts();

const groups = projects
  .map((project) => {
    const logs = allLogs
      .filter((entry) => entry.data.project.id === project.id)
      .sort(
        (a, b) =>
          a.data.sprint - b.data.sprint ||
          (a.data.week ?? Number.MAX_SAFE_INTEGER) - (b.data.week ?? Number.MAX_SAFE_INTEGER),
      );
    const posts = allPosts.filter((post) => post.data.project?.id === project.id);
    const multiSprint = new Set(logs.map((entry) => entry.data.sprint)).size > 1;
    return { project, logs, posts, multiSprint };
  })
  .filter((group) => group.logs.length + group.posts.length > 0);

// Non-project writing gets its own "General" section — including posts whose
// referenced project isn't published (draft project), so a live post is never
// invisible on the default blog view.
const publishedIds = new Set(projects.map((project) => project.id));
const general = allPosts.filter(
  (post) => !post.data.project || !publishedIds.has(post.data.project.id),
);

/** `Week 3` normally; `S2 · W3` once a project has more than one sprint. */
function weekLabel(group: (typeof groups)[number], entry: (typeof allLogs)[number]): string {
  const kind = entry.data.kind === 'retro' ? 'Retro' : `Week ${entry.data.week}`;
  return group.multiSprint ? `S${entry.data.sprint} · ${kind}` : kind;
}
---

<Base
  page="Blog"
  description="Build logs and essays, grouped by the project they belong to."
  jsonLd={[blogLd()]}
>
  <NavLite current="blog" />
  <main id="main" class="page">
    <PathCrumb segments={[{ label: 'blog' }]} />
    <h1>Blog</h1>
    <p class="lede">Build logs and essays, grouped by the project they belong to.</p>
    <BlogViewToggle current="projects" />

    {
      groups.length === 0 && general.length === 0 && (
        <>
          <p class="empty">First post is being written — subscribe and it'll find you.</p>
          <SubscribeNote />
        </>
      )
    }

    <div class="tree">
      {
        groups.map((group, index) => (
          <details class="proj" open={index === 0}>
            <summary>
              <ProjectMark id={group.project.id} title={group.project.data.title} />
              <span class="proj-name">{group.project.data.title}</span>
            </summary>
            <div class="body">
              <ul role="list">
                {group.logs.map((entry) => (
                  <TreeRow href={logPath(entry)} entry={entry} kicker={weekLabel(group, entry)} />
                ))}
              </ul>
              {group.posts.length > 0 && (
                <details class="essays" open>
                  <summary class="mono">Essays</summary>
                  <ul role="list">
                    {group.posts.map((post) => (
                      <TreeRow href={`/blog/${post.id}/`} entry={post} indent />
                    ))}
                  </ul>
                </details>
              )}
            </div>
          </details>
        ))
      }

      {
        general.length > 0 && (
          <details class="proj" open={groups.length === 0}>
            <summary>
              <ProjectMark id="_general" title="General Writing" />
              <span class="proj-name">General</span>
            </summary>
            <div class="body">
              <ul role="list">
                {general.map((post) => (
                  <TreeRow href={`/blog/${post.id}/`} entry={post} />
                ))}
              </ul>
            </div>
          </details>
        )
      }
    </div>
  </main>
</Base>

<style>
  main {
    padding-top: var(--s-8);
  }
  h1 {
    font-size: var(--step-4);
  }
  .lede {
    font-family: var(--font-body);
    color: var(--muted);
    margin-top: var(--s-2);
    margin-bottom: var(--s-4);
  }
  .empty {
    font-family: var(--font-body);
    font-style: italic;
    margin-top: var(--s-8);
  }
  .tree {
    margin-top: var(--s-8);
    display: grid;
    gap: var(--s-4);
  }
  .proj summary {
    display: flex;
    align-items: center;
    gap: var(--s-3);
    padding: var(--s-3) 0;
    cursor: pointer;
    list-style: none;
    border-bottom: 1px solid var(--line);
  }
  .proj summary::-webkit-details-marker {
    display: none;
  }
  .proj > summary::after {
    content: "＋";
    margin-left: auto;
    color: var(--muted);
    font-family: var(--font-mono);
  }
  .proj[open] > summary::after {
    content: "－";
  }
  .proj-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--step-2);
  }
  .body {
    padding: var(--s-3) 0 var(--s-4);
  }
  .body ul {
    padding: 0;
    display: grid;
  }
  .essays {
    margin-top: var(--s-4);
  }
  .essays > summary {
    color: var(--rose-ink);
    cursor: pointer;
    list-style: none;
    padding: var(--s-2) 0;
  }
  .essays > summary::-webkit-details-marker {
    display: none;
  }
  .essays > summary::before {
    content: "▸ ";
  }
  .essays[open] > summary::before {
    content: "▾ ";
  }
</style>
