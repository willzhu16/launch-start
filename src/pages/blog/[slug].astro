---
// Blog post page: same article layout as a log entry, minus
// the glance card and sprint kicker.
import { getEntry, render } from 'astro:content';
import NavLite from '../../components/NavLite.astro';
import PathCrumb from '../../components/PathCrumb.astro';
import SubscribeNote from '../../components/SubscribeNote.astro';
import TechChips from '../../components/TechChips.astro';
import VideoFacade from '../../components/VideoFacade.astro';
import { site } from '../../data/site';
import Base from '../../layouts/Base.astro';
import { published, publishedPosts } from '../../lib/content';
import { fmtLong, fmtMono } from '../../lib/dates';
import { blogPostingLd } from '../../lib/seo';

export async function getStaticPaths() {
  const posts = await publishedPosts();
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { title, description, date, updated, tags, videoId } = post.data;
const { Content } = await render(post);

// A post may reference a project that is still a draft (the blog index files such
// posts under "General" for the same reason). A draft project has no page in a
// prod build, so the teaser link only renders once the project is published.
const linkedProject = post.data.project ? await getEntry(post.data.project) : null;
const project = linkedProject ? (published([linkedProject])[0] ?? null) : null;

// Prev/next post, chronological.
const chrono = [...(await publishedPosts())].sort(
  (a, b) => a.data.date.getTime() - b.data.date.getTime(),
);
const idx = chrono.findIndex((p) => p.id === post.id);
const prevPost = idx > 0 ? chrono[idx - 1] : null;
const nextPost = idx >= 0 && idx < chrono.length - 1 ? chrono[idx + 1] : null;
---

<Base
  page={title}
  description={description}
  jsonLd={[
    blogPostingLd({
      title,
      description,
      path: `/blog/${post.id}/`,
      date,
      ...(updated ? { updated } : {}),
    }),
  ]}
>
  <NavLite current="blog" />
  <main id="main" class="prose-width">
    <PathCrumb segments={[{ label: 'blog', href: '/blog/' }, { label: post.id }]} />

    <header class="head">
      <p class="mono kicker">Blog · {fmtMono(date)} {date.getUTCFullYear()}</p>
      <h1>{title}</h1>
      <p class="byline">by {site.author} — {fmtLong(date)}</p>
      <div class="tags"><TechChips items={[...tags]} /></div>
    </header>

    <article class="prose story">
      <Content />
      {videoId && <VideoFacade videoId={videoId} />}
    </article>

    {
      project && (
        <aside class="project-link">
          <p>
            This post came out of a project: <strong>{project.data.title}</strong> — {' '}
            {project.data.pitch}
          </p>
          <a class="mono" href={`/projects/${project.id}/`}>
            Read the build →
          </a>
        </aside>
      )
    }

    <nav class="pn" aria-label="post navigation">
      {
        prevPost ? (
          <a href={`/blog/${prevPost.id}/`}>← {prevPost.data.title}</a>
        ) : (
          <a href="/blog/">← All posts</a>
        )
      }
      {nextPost ? <a href={`/blog/${nextPost.id}/`}>{nextPost.data.title} →</a> : <span />}
    </nav>

    <SubscribeNote compact />
  </main>
</Base>

<style>
  main {
    padding-top: var(--s-8);
  }
  .head {
    text-align: center;
    margin-block: var(--s-8) var(--s-6);
  }
  .kicker {
    color: var(--rose-ink);
  }
  h1 {
    font-size: var(--step-4);
    margin-block: var(--s-3);
  }
  .byline {
    font-family: var(--font-body);
    font-style: italic;
    color: var(--muted);
  }
  .tags {
    display: flex;
    justify-content: center;
    margin-top: var(--s-3);
  }
  .story {
    margin-inline: auto;
  }
  .project-link {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--r-m);
    padding: var(--s-6);
    margin-top: var(--s-12);
  }
  .project-link p {
    font-family: var(--font-body);
    margin-bottom: var(--s-2);
  }
  .project-link a {
    text-decoration: none;
  }
  .project-link a:hover {
    text-decoration: underline;
  }
  .pn {
    display: flex;
    justify-content: space-between;
    gap: var(--s-4);
    margin-top: var(--s-12);
    padding-top: var(--s-4);
    border-top: 1px solid var(--line);
    font-family: var(--font-body);
  }
  @media (max-width: 500px) {
    .pn {
      flex-direction: column;
    }
  }
</style>